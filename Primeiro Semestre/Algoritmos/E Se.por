programa {
  funcao inicio() {

    caracter Y

    escreva ("Eae tranquilébinho(a), qual é a sua sexualidade? Responda com M ou F \n")
    leia(Y)

         se (Y == "M" ou Y == "m")
    {
      escreva ("Aaaah, então você é Homem!")
    }
        senao
        {
          escreva ("Você é meninaaaa!!!!")
        }

  }
}
